# Local server
HOST=0.0.0.0
PORT=4173

# Optional email delivery through Resend.
# Inquiries are still stored locally in data/inquiries.ndjson when these are blank.
RESEND_API_KEY=
INQUIRY_TO_EMAIL=
INQUIRY_FROM_EMAIL=Nexora Website <onboarding@resend.dev>

# Optional Google Calendar follow-up. Keep the private key in local/Vercel secrets only.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_TIME_ZONE=Asia/Jakarta
